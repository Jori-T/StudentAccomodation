<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                app:tint="#FFFFFF"
                android:background="@drawable/bg_circle_teal"
                android:padding="8dp"
                android:contentDescription="Back"
                android:layout_marginTop="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Account"
                android:textSize="28sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join StudentNest — stored securely in Firebase"
                android:textSize="13sp"
                android:textColor="#99FFFFFF"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="16dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Role -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="I am a:" android:textColor="@color/text_secondary" android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>
                    <RadioGroup android:id="@+id/rgRole"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="16dp">
                        <RadioButton android:id="@+id/rbStudent" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Student" android:checked="true"
                            android:buttonTint="@color/brand_teal" android:textColor="@color/text_primary"/>
                        <RadioButton android:id="@+id/rbProvider" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Landlord / Provider"
                            android:buttonTint="@color/brand_teal" android:textColor="@color/text_primary"/>
                    </RadioGroup>

                    <!-- Full Name -->
                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilName"
                        style="@style/InputField" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Full Name" app:startIconDrawable="@drawable/ic_profile" app:startIconTint="@color/brand_teal">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etName"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textPersonName" android:imeOptions="actionNext" android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Student ID -->
                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilStudentId"
                        style="@style/InputField" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Student ID" android:layout_marginTop="14dp"
                        app:startIconDrawable="@drawable/ic_receipt" app:startIconTint="@color/brand_teal">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etStudentId"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="text" android:imeOptions="actionNext" android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Institution -->
                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilInstitution"
                        style="@style/InputField" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Institution (e.g. BAC, UB)" android:layout_marginTop="14dp"
                        app:startIconDrawable="@drawable/ic_map" app:startIconTint="@color/brand_teal">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etInstitution"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="text" android:imeOptions="actionNext" android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilEmail"
                        style="@style/InputField" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Email Address" android:layout_marginTop="14dp"
                        app:startIconDrawable="@drawable/ic_notification" app:startIconTint="@color/brand_teal">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etEmail"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textEmailAddress" android:imeOptions="actionNext" android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Phone -->
                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilPhone"
                        style="@style/InputField" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Phone Number" android:layout_marginTop="14dp"
                        app:startIconDrawable="@drawable/ic_phone" app:startIconTint="@color/brand_teal">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etPhone"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="phone" android:imeOptions="actionNext" android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password -->
                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilPassword"
                        style="@style/InputField" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Password" android:layout_marginTop="14dp"
                        app:startIconDrawable="@drawable/ic_security" app:startIconTint="@color/brand_teal"
                        app:endIconMode="password_toggle">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etPassword"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textPassword" android:imeOptions="actionNext" android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Confirm Password -->
                    <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilConfirmPassword"
                        style="@style/InputField" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Confirm Password" android:layout_marginTop="14dp"
                        app:startIconDrawable="@drawable/ic_security" app:startIconTint="@color/brand_teal"
                        app:endIconMode="password_toggle">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:inputType="textPassword" android:imeOptions="actionDone" android:textColor="@color/text_primary"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView android:id="@+id/tvError" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text=""
                        android:textColor="#E74C3C" android:textSize="12sp"
                        android:visibility="gone" android:layout_marginTop="8dp"/>

                    <com.google.android.material.button.MaterialButton android:id="@+id/btnRegister"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:text="Create Account" android:textSize="15sp" android:textColor="@color/white"
                        android:layout_marginTop="24dp" android:backgroundTint="@color/brand_teal" app:cornerRadius="12dp"/>

                    <ProgressBar android:id="@+id/progressBar" android:layout_width="32dp" android:layout_height="32dp"
                        android:layout_gravity="center" android:layout_marginTop="8dp"
                        android:indeterminateTint="@color/brand_teal" android:visibility="gone"/>

                    <TextView android:id="@+id/tvLogin" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Already have an account? Sign In"
                        android:textColor="@color/brand_teal" android:textSize="13sp"
                        android:layout_gravity="center" android:layout_marginTop="16dp" android:padding="8dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <View android:layout_width="match_parent" android:layout_height="32dp"/>
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

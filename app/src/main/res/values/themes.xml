<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.StudentAccomodation" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryVariant">@color/brand_navy</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_teal</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/brand_navy</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
    </style>

    <style name="Theme.StudentNest.Splash" parent="Theme.StudentAccomodation">
        <item name="android:statusBarColor">@color/splash_start</item>
        <item name="android:navigationBarColor">@color/splash_end</item>
        <item name="android:windowBackground">@color/brand_navy</item>
    </style>

    <style name="InputField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/brand_teal</item>
        <item name="android:textColorHint">@color/brand_teal</item>
        <item name="boxBackgroundColor">@color/white</item>
    </style>

    <style name="splash_start" parent="">
        <item name="android:color">@color/brand_navy</item>
    </style>

    <style name="splash_end" parent="">
        <item name="android:color">@color/brand_teal</item>
    </style>
</resources>
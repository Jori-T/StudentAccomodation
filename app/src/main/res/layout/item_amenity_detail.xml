<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical" android:padding="8dp">
    <FrameLayout android:layout_width="36dp" android:layout_height="36dp" android:background="@drawable/bg_circle_teal">
        <ImageView android:id="@+id/ivAmenityIcon" android:layout_width="18dp" android:layout_height="18dp"
            android:layout_gravity="center" android:contentDescription="Amenity"/>
    </FrameLayout>
    <TextView android:id="@+id/tvAmenityName" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="WiFi" android:textSize="13sp"
        android:textColor="@color/text_primary" android:layout_marginStart="10dp"/>
</LinearLayout>